generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  DEPOSIT
  BET
  WIN
  BONUS
}

enum GameType {
  MINES
  PLINKO
  ROULETTE
  BLACKJACK
}

enum GameState {
  ACTIVE
  COMPLETED
}

enum FairnessMode {
  PROVABLY_FAIR
  CUSTOM
}

enum OutcomeType {
  WIN
  LOSS
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  username     String        @unique
  passwordHash String
  avatar       String?
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  wallet       Wallet?
  seeds        Seed[]
  gameSessions GameSession[]
  forcedOutcomes ForcedOutcome[] @relation("ForcedOutcomeTarget")
  createdForcedOutcomes ForcedOutcome[] @relation("ForcedOutcomeCreator")
}

model Wallet {
  id           String        @id @default(cuid())
  userId       String        @unique
  balance      Decimal       @default(10000) @db.Decimal(18, 8)
  currency     String        @default("USD")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id            String          @id @default(cuid())
  walletId      String
  type          TransactionType
  amount        Decimal         @db.Decimal(18, 8)
  balanceBefore Decimal         @db.Decimal(18, 8)
  balanceAfter  Decimal         @db.Decimal(18, 8)
  description   String?
  gameSessionId String?
  createdAt     DateTime        @default(now())
  wallet        Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  gameSession   GameSession?    @relation(fields: [gameSessionId], references: [id])
}

model GameSession {
  id             String        @id @default(cuid())
  userId         String
  gameType       GameType
  betAmount      Decimal       @db.Decimal(18, 8)
  multiplier     Decimal?      @db.Decimal(18, 8)
  payout         Decimal?      @db.Decimal(18, 8)
  profit         Decimal?      @db.Decimal(18, 8)
  serverSeed     String
  serverSeedHash String
  clientSeed     String
  nonce          Int
  result         Json?
  state          GameState     @default(ACTIVE)
  fairnessMode   FairnessMode  @default(PROVABLY_FAIR)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
}

model Seed {
  id             String   @id @default(cuid())
  userId         String
  serverSeed     String
  serverSeedHash String
  clientSeed     String
  nonce          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameConfig {
  id             String       @id @default(cuid())
  gameType       GameType     @unique
  fairnessMode   FairnessMode @default(PROVABLY_FAIR)
  customHouseEdge Decimal?    @db.Decimal(5, 4)
  customSettings Json?
  updatedAt      DateTime     @updatedAt
}

model SiteConfig {
  id                  String   @id @default("default")
  showProvablyFair    Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

model ForcedOutcome {
  id                String      @id @default(cuid())
  userId            String
  gameType          GameType
  outcomeType       OutcomeType
  multiplierOverride Decimal?   @db.Decimal(18, 8)
  active            Boolean     @default(true)
  createdBy         String
  createdAt         DateTime    @default(now())
  user              User        @relation("ForcedOutcomeTarget", fields: [userId], references: [id], onDelete: Cascade)
  creator           User        @relation("ForcedOutcomeCreator", fields: [createdBy], references: [id], onDelete: Cascade)
}
