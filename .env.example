# ===========================================
# CasinoR - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- Database ---
# PostgreSQL connection string (use a cloud provider like Neon, Supabase, or Railway for Vercel)
DATABASE_URL="postgresql://user:password@host:5432/casinor?sslmode=require"

# --- Authentication (Auth.js / NextAuth) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_SECRET="your-auth-secret-here"

# Full URL of your app (set automatically on Vercel, set manually for local dev)
NEXTAUTH_URL="http://localhost:3000"

# --- Socket.io Chat (Optional) ---
# Only needed if running the custom Socket.io server for real-time chat
# On Vercel serverless, leave this unset to gracefully disable chat
# NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
